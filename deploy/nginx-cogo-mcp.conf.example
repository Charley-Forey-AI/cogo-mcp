# Add this `location` block inside your existing nginx `server { ... }` (HTTPS or HTTP).
# Match `.env` on the server: FASTMCP_PORT=8880 and FASTMCP_STREAMABLE_HTTP_PATH=/mcp/cogo
#
# Public MCP base URL: https://your.domain/mcp/cogo

location /mcp/cogo {
    proxy_pass http://127.0.0.1:8880;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_connect_timeout 60s;
    proxy_buffering off;

    # client_max_body_size 20m;
}
