# Copy to `.env` and fill in values. Do not commit `.env`.

# Required for OpenAI Responses API calls from tools.
OPENAI_API_KEY=

# Default fine-tuned model when tools omit `model` (full id from OpenAI; usually starts with ft:).
OPENAI_FINETUNED_MODEL=ft:gpt-4.1-nano-2025-04-14:trimble:project1:DDahEMRm

# Streamable HTTP MCP (defaults match server.py)
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=8000
FASTMCP_STREAMABLE_HTTP_PATH=/mcp

# Optional: transport when running `python server.py` with no CLI arg.
# Values: streamable-http | stdio | sse
# MCP_TRANSPORT=streamable-http
